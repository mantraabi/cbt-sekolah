{
  "apps": [{
    "name": "server-cbt",
    "script": "app.js",
    "instances": 1,
    "exec_mode": "fork",
    "autorestart": true,
    "watch": false,
    "max_memory_restart": "500M",
    "env": {
      "NODE_ENV": "development"
    },
    "env_production": {
      "NODE_ENV": "production"
    },
    "log_date_format": "YYYY-MM-DD HH:mm:ss",
    "error_file": "./logs/error.log",
    "out_file": "./logs/output.log",
    "merge_logs": true,
    "max_restarts": 10,
    "min_uptime": "10s"
  }]
}

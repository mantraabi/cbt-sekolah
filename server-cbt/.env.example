# Server CBT — Environment Variables
# Copy file ini ke .env dan isi dengan nilai yang benar

PORT=5000
NODE_ENV=production

# Database MySQL
DB_HOST=localhost
DB_NAME=db_cbt_sekolah
DB_USER=user_cbt
DB_PASS=YOUR_DB_PASSWORD

# JWT Secret (generate: openssl rand -hex 32)
JWT_SECRET=YOUR_JWT_SECRET_HERE
JWT_EXPIRES_IN=12h

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# License Secret (harus sama dengan license generator)
LICENSE_SECRET=YOUR_LICENSE_SECRET_HERE
